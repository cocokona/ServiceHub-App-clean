# ServiceHub Admin Dashboard — Environment Configuration
#
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Use the SUPABASE ANON KEY (public), NOT the service_role key.
# The anon key is safe to expose in the browser because all access is enforced
# by Row Level Security. The service_role key must NEVER be embedded in client
# code. For admin-wide data access, promote an account with `is_admin = true`
# (see supabase/migrations/00015_admin_rls.sql).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
