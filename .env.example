# ============================================================================
# ServiceHub Pro — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All client-side env vars MUST be prefixed with EXPO_PUBLIC_ so that
# Expo bundles them at build time.
# ============================================================================

# Supabase Project URL — find in: Supabase Dashboard > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key — safe to expose in client code (protected by RLS).
# NEVER expose the service_role key in the app.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# REST API Base URL (legacy / optional — used by src/api/client.ts)
# iOS Simulator:   http://localhost:3000
# Android Emulator: http://10.0.2.2:3000
# Physical Device:  http://<YOUR_MACHINE_IP>:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
